generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  relatedPeople RelatedPerson[]

  @@map("user")
}

model RelatedPerson {
  id        String   @id @default(cuid())
  userId    String
  name      String
  email     String?
  phone     String?
  notes     String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  debts Debt[]

  @@index([userId, name])
  @@map("related_person")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String   @unique
  ipAddress String?
  userAgent String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

enum BillStatus {
  DRAFT
  REVIEWED
  CONFIRMED
  DISCARDED
}

enum BillItemType {
  FIXED
  VARIABLE
}

enum Recurrence {
  NONE
  MONTHLY
  WEEKLY
  YEARLY
}

enum DebtStatus {
  OPEN
  PAID
  OVERDUE
  CANCELED
}

enum DebtSource {
  BILL
  MANUAL
}

enum DebtDirection {
  PAYABLE
  RECEIVABLE
}

enum IncomeType {
  CLT
  PJ
}

model Income {
  id          String     @id @default(cuid())
  userId      String
  type        IncomeType
  amount      Decimal    @db.Decimal(12, 2)
  date        DateTime
  description String?    @db.Text
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId, date])
  @@index([userId, type])
  @@map("income")
}

model Bill {
  id          String     @id @default(cuid())
  userId      String
  fileName    String
  status      BillStatus @default(DRAFT)
  rawText     String     @db.LongText
  totalAmount Decimal    @default(0) @db.Decimal(12, 2)
  issuedAt    DateTime?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items BillItem[]
  debts Debt[]

  @@index([userId, createdAt])
  @@map("bill")
}

model BillItem {
  id          String       @id @default(cuid())
  billId      String
  description String
  amount      Decimal      @db.Decimal(12, 2)
  category    String
  type        BillItemType @default(VARIABLE)
  recurrence  Recurrence   @default(NONE)
  selected    Boolean      @default(true)
  createdAt   DateTime     @default(now())

  bill Bill  @relation(fields: [billId], references: [id], onDelete: Cascade)
  debt Debt?

  @@index([billId])
  @@map("bill_item")
}

model Debt {
  id          String       @id @default(cuid())
  userId      String
  billId      String?
  billItemId  String?      @unique
  parentDebtId String?
  personId    String?
  title       String
  amount      Decimal      @db.Decimal(12, 2)
  category    String
  type        BillItemType @default(VARIABLE)
  recurrence  Recurrence   @default(NONE)
  direction   DebtDirection @default(PAYABLE)
  status      DebtStatus   @default(OPEN)
  source      DebtSource   @default(MANUAL)
  dueDate     DateTime
  paidAt      DateTime?
  notes       String?      @db.Text
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  bill     Bill?     @relation(fields: [billId], references: [id], onDelete: SetNull)
  billItem BillItem? @relation(fields: [billItemId], references: [id], onDelete: SetNull)
  parentDebt Debt?   @relation("DebtChildren", fields: [parentDebtId], references: [id], onDelete: SetNull)
  childDebts Debt[]  @relation("DebtChildren")
  person   RelatedPerson? @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([userId, dueDate])
  @@index([userId, status])
  @@index([userId, direction])
  @@index([parentDebtId])
  @@index([personId])
  @@map("debt")
}
